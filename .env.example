# DebateSphere — environment variable reference
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# PostgreSQL connection string.
# Accepted formats:
#   postgresql://user:password@host:5432/dbname
#   postgres://user:password@host:5432/dbname
#   jdbc:postgresql://host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/debatesphere

# Secret used to sign JWT tokens.
# Generate a strong random value: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret-key

# Backend port (optional — defaults to 8080 if not set)
# PORT=8080
